# Front-end byline date format. English drops to a plain Spanish date.
# msgid runtime:  jS \of F Y   ->  "8th of June 2026"
# msgstr runtime: j \d\e F Y   ->  "8 de junio 2026"
msgctxt "embedded post date format"
msgid "jS \\of F Y"
msgstr "j \\d\\e F Y"

msgid "%1$s, by %2$s"
msgstr "%1$s, por %2$s"

msgid "Unknown Author"
msgstr "Autor desconocido"

msgid "Untitled"
msgstr "Sin título"

msgid "Read more..."
msgstr "Leer más..."

msgid "Settings"
msgstr "Ajustes"

msgid "Default Source"
msgstr "Fuente predeterminada"

msgid "Invalid endpoint URL."
msgstr "URL del endpoint no válida."

msgid "No posts found."
msgstr "No se han encontrado entradas."

msgid "Unable to parse response from API. Invalid JSON received."
msgstr "No se ha podido procesar la respuesta de la API. JSON no válido."

msgid "Unable to fetch posts. Error: %s. Please check your endpoint URL in the plugin settings."
msgstr "No se han podido obtener las entradas. Error: %s. Comprueba la URL del endpoint en los ajustes del plugin."

msgid "Unable to fetch posts. Server returned HTTP error %d. Please verify the endpoint URL is correct."
msgstr "No se han podido obtener las entradas. El servidor devolvió el error HTTP %d. Verifica que la URL del endpoint sea correcta."

msgid "The requested feed source \"%s\" is currently disabled."
msgstr "La fuente solicitada «%s» está desactivada actualmente."

msgid "Feed source \"%s\" not found. Please check your source ID in the plugin settings."
msgstr "No se ha encontrado la fuente «%s». Comprueba el ID de la fuente en los ajustes del plugin."

# --- 3.7.0: Load More button ---
msgid "Load More"
msgstr "Cargar más"

msgid "Loading…"
msgstr "Cargando…"

msgid "Could not load more posts. Please try again."
msgstr "No se han podido cargar más entradas. Inténtalo de nuevo."

msgid "This feed has expired. Please refresh the page."
msgstr "Esta fuente ha caducado. Actualiza la página."

msgid "Invalid request."
msgstr "Solicitud no válida."

# --- 3.7.0: per-feed excerpt length ---
msgid "Excerpt Length"
msgstr "Longitud del extracto"

msgid "Default Excerpt Length"
msgstr "Longitud de extracto predeterminada"

msgid "Excerpt"
msgstr "Extracto"

msgid "characters"
msgstr "caracteres"

msgid "%d chars"
msgstr "%d caracteres"

msgid "Full"
msgstr "Completo"

msgid "Number of posts to load per batch (%d-%d). Each \"Load More\" click loads another batch."
msgstr "Número de entradas a cargar por lote (%d-%d). Cada clic en «Cargar más» carga otro lote."

msgid "Maximum excerpt length for this feed, in characters (0-%d). Use 0 to show the full excerpt from the source. Default: %d."
msgstr "Longitud máxima del extracto para esta fuente, en caracteres (0-%d). Usa 0 para mostrar el extracto completo de la fuente. Predeterminado: %d."

msgid "Default maximum excerpt length, in characters (0-%1$d). Use 0 to show the full excerpt from the source. Default: %2$d. Each feed source can override this."
msgstr "Longitud máxima del extracto predeterminada, en caracteres (0-%1$d). Usa 0 para mostrar el extracto completo de la fuente. Predeterminado: %2$d. Cada fuente puede sobrescribirla."
